# AWS Bedrock (required)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-opus-4-6-v1:1m

# FRED API (required for macro data)
FRED_API_KEY=

# Alpha Vantage (optional - news sentiment)
ALPHA_VANTAGE_API_KEY=

# NewsAPI (optional - news articles)
NEWS_API_KEY=

# Reddit (optional - social sentiment, falls back to public JSON)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
